# ── Webex Bot ──────────────────────────────────────────────────────────────────
# Get this from https://developer.webex.com/my-apps → Create a Bot
WEBEX_ACCESS_TOKEN=your_webex_bot_token_here

# The public URL where your bot is hosted + /webhook path
# On Render this looks like: https://webex-ai-bot-xxxx.onrender.com/webhook
WEBHOOK_URL=https://your-server.com/webhook

# ── Groq API (Free — no credit card needed) ────────────────────────────────────
# Sign up at https://console.groq.com and go to API Keys → Create API Key
# Free tier: 14,400 requests/day · 30 RPM · No credit card needed
GROQ_API_KEY=your_groq_api_key_here

# ── Optional settings ──────────────────────────────────────────────────────────
PORT=3000

# AI model to use (default is the most capable free model on Groq)
# Other options: llama-3.1-8b-instant (faster), llama-4-scout-17b-16e-instruct
# Full list: https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.3-70b-versatile

# Custom bot persona — uncomment and edit to change how the bot behaves
# BOT_PERSONA=You are a sarcastic but helpful tech support bot for our team.
